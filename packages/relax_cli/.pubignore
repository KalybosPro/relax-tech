# NOTE: `.gitignore` ignores any `build/` directory. That pattern also matches
# the source directory `lib/src/commands/build/`, which would silently drop the
# build commands from the published package (and break dartdoc / analysis on
# pub.dev). Re-include it explicitly here.
!lib/src/commands/build/
!lib/src/commands/build/**

# Large marketing assets not needed in the published package
assets/logo_playstore.png
assets/logo.png
cahier_des_charges.md
posts.md
*.zip

# Carousel banner tooling + generated images — build-time/marketing only.
assets/carousel/

# Example platform directories (heavy, not needed for pub.dev)
example/android/
example/ios/
example/macos/
example/linux/
example/windows/
example/web/
example/packages/

# Environment files should remain in repo for local example use, but not in published package
example/.env.development
example/.env.production
example/.env.staging

# Build artifacts
pubspec.lock
